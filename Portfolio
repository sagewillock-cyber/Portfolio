            --card-bg: #141414;
            --accent: #00f2ff;
            --text: #e0e0e0;
            --muted: #888;
        }
        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 40px 20px; line-height: 1.6; }
        .container { max-width: 800px; margin: 0 auto; }
