        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px; }
        a { background: var(--card-bg); padding: 20px; display: block; text-decoration: none; color: var(--text); border: 1px solid #333; border-radius: 8px; transition: 0.3s; font-size: 0.9rem; }
        a:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0, 242, 255, 0.1); }
        footer { text-align: center; margin-top: 80px; color: var(--muted); font-size: 0.8rem; }
    </style>
